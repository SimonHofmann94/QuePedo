{
  "expo": {
    "name": "Chingón",
    "slug": "chingon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.chingon",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chingon.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF7ED"
      },
      "package": "com.chingon.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "QuePedo needs access to your microphone for speaking exercises.",
          "speechRecognitionPermission": "QuePedo needs access to speech recognition for speaking exercises."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
